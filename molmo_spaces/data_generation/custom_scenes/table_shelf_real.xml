<mujoco model="table_shelf_real">
  <compiler angle="radian" autolimits="true" boundmass="0" balanceinertia="true"/>
  <option impratio="10" gravity="0 0 -9.8" integrator="implicitfast" cone="elliptic" jacobian="sparse" noslip_iterations="4">
    <flag multiccd="enable" contact="enable" warmstart="enable"/>
  </option>
  <size njmax="8000" nconmax="8000"/>
  <visual>
    <global offwidth="1280" offheight="720"/>
    <map znear="0.001"/>
    <headlight ambient="0.42 0.42 0.42" diffuse="0.55 0.55 0.55"/>
  </visual>
  <asset>
    <texture name="woodtex" type="2d" builtin="flat" rgb1="0.55 0.39 0.25" width="32" height="32"/>
    <material name="wood" texture="woodtex" reflectance="0.05"/>
    <texture name="floortex" type="2d" builtin="checker" rgb1="0.45 0.43 0.40" rgb2="0.38 0.36 0.34" width="300" height="300"/>
    <material name="floormat" texture="floortex" texrepeat="10 10" reflectance="0.05"/>
  </asset>
  <default>
    <default class="furniture">
      <geom contype="8" conaffinity="15" group="0" friction="0.9 0.9 0.001"
            solref="0.02 1" solimp="0.998 0.998 0.001" density="700" material="wood"/>
    </default>
  </default>
  <worldbody>
    <light pos="0.3 0.5 2.6" dir="0 0 -1" diffuse="0.65 0.65 0.65"/>
    <light pos="-0.8 -0.8 2.2" dir="0.3 0.3 -1" diffuse="0.3 0.3 0.3"/>
    <geom name="floor" type="plane" size="5 5 0.1" pos="0 0 0" material="floormat" contype="8" conaffinity="15"/>
    <!-- room walls (back +x and side -y); camera side (+y) and front stay open -->
    <geom name="wall_back" type="box" pos="1.45 0 1.1" size="0.04 1.8 1.1" rgba="0.78 0.75 0.70 1" contype="8" conaffinity="15"/>
    <geom name="wall_side" type="box" pos="0.2 -1.05 1.1" size="1.3 0.04 1.1" rgba="0.80 0.78 0.73 1" contype="8" conaffinity="15"/>
    <!-- robot pedestal (cabinet look; visual-only so it can't collide with the robot mount) -->
    <geom name="pedestal" type="box" pos="0 0 0.29" size="0.16 0.16 0.29" material="wood"
          contype="0" conaffinity="0"/>
    <!-- work table in front of the robot: top at z=0.46 -->
    <body name="table" pos="0.62 0 0">
      <geom name="table_top" class="furniture" type="box" pos="0 0 0.44" size="0.40 0.50 0.02"/>
      <geom name="table_leg1" class="furniture" type="box" pos="0.34 0.44 0.21" size="0.03 0.03 0.21"/>
      <geom name="table_leg2" class="furniture" type="box" pos="0.34 -0.44 0.21" size="0.03 0.03 0.21"/>
      <geom name="table_leg3" class="furniture" type="box" pos="-0.34 0.44 0.21" size="0.03 0.03 0.21"/>
      <geom name="table_leg4" class="furniture" type="box" pos="-0.34 -0.44 0.21" size="0.03 0.03 0.21"/>
    </body>
    <!-- shelf unit standing on the floor behind the table (real bookshelf geometry) -->
    <body name="bookshelf" pos="1.18 0 0">
      <geom name="shelf_side_l" class="furniture" type="box" pos="0 0.45 0.75" size="0.16 0.02 0.75"/>
      <geom name="shelf_side_r" class="furniture" type="box" pos="0 -0.45 0.75" size="0.16 0.02 0.75"/>
      <geom name="shelf_board0" class="furniture" type="box" pos="0 0 0.50" size="0.16 0.45 0.02"/>
      <geom name="shelf_board1" class="furniture" type="box" pos="0 0 0.95" size="0.16 0.45 0.02"/>
      <geom name="shelf_board2" class="furniture" type="box" pos="0 0 1.40" size="0.16 0.45 0.02"/>
      <geom name="shelf_back" class="furniture" type="box" pos="0.14 0 0.75" size="0.02 0.45 0.75"/>
    </body>
  </worldbody>
</mujoco>
