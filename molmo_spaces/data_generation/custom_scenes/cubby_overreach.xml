<mujoco model="cubby_overreach">
  <compiler angle="radian" autolimits="true" boundmass="0" balanceinertia="true"/>
  <option impratio="10" gravity="0 0 -9.8" integrator="implicitfast" cone="elliptic" jacobian="sparse" noslip_iterations="4">
    <flag multiccd="enable" contact="enable" warmstart="enable"/>
  </option>
  <size njmax="6000" nconmax="6000"/>
  <visual><global offwidth="1280" offheight="720"/><map znear="0.001"/>
    <headlight ambient="0.5 0.5 0.5" diffuse="0.65 0.65 0.65"/></visual>
  <asset>
    <texture name="boxtex" type="2d" builtin="flat" rgb1="0.93 0.72 0.18" width="32" height="32"/>
    <material name="boxmat" texture="boxtex" reflectance="0.05"/>
    <texture name="floortex" type="2d" builtin="checker" rgb1="0.46 0.46 0.48" rgb2="0.40 0.40 0.42" width="300" height="300"/>
    <material name="floormat" texture="floortex" texrepeat="10 10" reflectance="0.05"/>
  </asset>
  <default>
    <default class="cub">
      <geom contype="8" conaffinity="15" group="0" friction="0.9 0.9 0.001"
            solref="0.02 1" solimp="0.998 0.998 0.001" density="500" material="boxmat"/>
    </default>
  </default>
  <worldbody>
    <light name="l_key" pos="0.4 0.5 2.6" dir="0 0 -1" diffuse="0.95 0.95 0.95"/>
    <light name="l_fill" pos="-0.6 -0.7 2.1" dir="0.3 0.3 -1" diffuse="0.5 0.5 0.5"/>
    <geom name="floor" type="plane" size="5 5 0.1" pos="0 0 0" material="floormat" contype="8" conaffinity="15"/>
    <!-- open-top cubby box: floor + back + sides static; FRONT WALL + DIVIDER mocap (knobs) -->
    <geom name="cub_floor" class="cub" type="box" pos="0.62 0 0.42" size="0.22 0.30 0.02"/>
    <geom name="cub_stand" class="cub" type="box" pos="0.62 0 0.20" size="0.18 0.26 0.20" rgba="0.85 0.62 0.15 1"/>
    <geom name="cub_back" class="cub" type="box" pos="0.85 0 0.62" size="0.015 0.30 0.22"/>
    <geom name="cub_left" class="cub" type="box" pos="0.62 0.30 0.62" size="0.22 0.015 0.22"/>
    <geom name="cub_right" class="cub" type="box" pos="0.62 -0.30 0.62" size="0.22 0.015 0.22"/>
    <body name="front_wall" mocap="true" pos="0.40 0 0.56"><geom name="front_wall_g" class="cub" type="box" size="0.015 0.30 0.16"/></body>
    <body name="divider" mocap="true" pos="0 1.0 -2.0"><geom name="divider_g" class="cub" type="box" size="0.20 0.012 0.14" rgba="0.9 0.68 0.2 1"/></body>
  </worldbody>
</mujoco>
